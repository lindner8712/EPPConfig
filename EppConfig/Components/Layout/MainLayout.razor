@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject EppConfig.Services.BlocklyStateService BlocklyState
@inject EppConfig.Services.PersistentLogService PersistentLog
@inject ISnackbar Snackbar

<MudThemeProvider Theme="@_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="app-shell">
    <MudAppBar Elevation="0" Dense="true" Class="app-shell__appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="DrawerToggle" />
        <div class="app-shell__brand">
            <MudText Typo="Typo.caption" Class="app-shell__eyebrow">PIA inspiriertes Interface</MudText>
            <MudText Typo="Typo.h6">EppConfig</MudText>
        </div>
        <MudSpacer />
        <MudTooltip Text="Blockly XML importieren">
            <MudIconButton Icon="@Icons.Material.Filled.FileUpload" Color="Color.Primary" OnClick="ImportBlocklyXmlAsync" />
        </MudTooltip>
        <MudTooltip Text="Blockly XML exportieren">
            <MudIconButton Icon="@Icons.Material.Filled.FileDownload" Color="Color.Primary" OnClick="ExportBlocklyXmlAsync" />
        </MudTooltip>
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Text" Icon="@Icons.Material.Filled.LightMode">
            Hell
        </MudChip>
    </MudAppBar>
    <MudDrawer id="nav-drawer" @bind-Open="_drawerOpen" Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Md" ClipMode="DrawerClipMode.Always" Elevation="0" Class="app-shell__drawer">
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="app-shell__content">
        <MudContainer MaxWidth="MaxWidth.False" Class="app-shell__content-inner">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x1F5D9;</span>
</div>

@code {
    private bool _drawerOpen = true;
    private MudTheme? _theme;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _theme = new()
        {
            PaletteLight = _lightPalette,
            LayoutProperties = new LayoutProperties
            {
                DrawerWidthLeft = "296px",
                AppbarHeight = "72px"
            }
        };
    }

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private async Task ImportBlocklyXmlAsync()
    {
        var importedXml = await JS.InvokeAsync<string>("blocklyInterop.importXmlFile");
        if (!string.IsNullOrWhiteSpace(importedXml))
        {
            BlocklyState.SetXml(importedXml, "Import");

            var masterCount = BlocklyState.Masters.Count;
            var eppCount = BlocklyState.Masters.Sum(master => master.Children.Count);
            var moduleCount = BlocklyState.Masters.Sum(master => master.Children.Sum(child => child.Channel1.Count + child.Channel2.Count));
            var firstBmk = BlocklyState.Masters.Select(master => master.Bmk).FirstOrDefault(bmk => !string.IsNullOrWhiteSpace(bmk)) ?? "-";

            PersistentLog.Log("Info", "Import", $"Blockly-XML importiert (Master: {masterCount}, EPP1322: {eppCount}, Module: {moduleCount}).", bmk: firstBmk);
            Snackbar.Add("Blockly-XML importiert.", Severity.Success);
        }
    }

    private async Task ExportBlocklyXmlAsync()
    {
        var xml = BlocklyState.Xml;
        if (string.IsNullOrWhiteSpace(xml))
        {
            xml = await JS.InvokeAsync<string>("blocklyInterop.getXml");
            BlocklyState.SetXml(xml, "ExportSync");
        }

        await JS.InvokeVoidAsync("blocklyInterop.exportXmlContent", xml, "eppconfig-blockly.xml");

        var masterCount = BlocklyState.Masters.Count;
        var eppCount = BlocklyState.Masters.Sum(master => master.Children.Count);
        var moduleCount = BlocklyState.Masters.Sum(master => master.Children.Sum(child => child.Channel1.Count + child.Channel2.Count));
        var firstBmk = BlocklyState.Masters.Select(master => master.Bmk).FirstOrDefault(bmk => !string.IsNullOrWhiteSpace(bmk)) ?? "-";

        PersistentLog.Log("Info", "Export", $"Blockly-XML exportiert (Master: {masterCount}, EPP1322: {eppCount}, Module: {moduleCount}).", bmk: firstBmk);
        Snackbar.Add("Blockly-XML exportiert.", Severity.Success);
    }

    private readonly PaletteLight _lightPalette = new()
    {
        Primary = "#9f1d35",
        Secondary = "#1f2240",
        Tertiary = "#687086",
        Surface = "#ffffff",
        Background = "#f4f5f8",
        BackgroundGray = "#eceff4",
        AppbarText = "#1f2240",
        AppbarBackground = "rgba(255,255,255,0.94)",
        DrawerBackground = "#ffffff",
        DrawerText = "#1f2240",
        DrawerIcon = "#9f1d35",
        TextPrimary = "#1f2240",
        TextSecondary = "#5f657a",
        ActionDefault = "#1f2240",
        ActionDisabled = "#b9bfcc",
        ActionDisabledBackground = "#eef1f6",
        Divider = "#d9deea",
        LinesDefault = "#d9deea",
        TableLines = "#e4e8f0",
        Success = "#2e7d5a",
        Warning = "#d98a00",
        Error = "#b3261e",
        Info = "#4064d7",
        GrayLight = "#dde2ec",
        GrayLighter = "#f8f9fc",
        Black = "#11162a"
    };
}
