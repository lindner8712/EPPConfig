@page "/logger"
@rendermode InteractiveServer
@inject EppConfig.Services.PersistentLogService PersistentLog
@implements IDisposable

<PageTitle>Logger</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Logger</MudText>
<MudText Typo="Typo.body2" Class="mb-4">Persistente Protokollierung (Datei-basiert)</MudText>

<MudDataGrid T="LogEntry" Items="@_entries" Bordered="true" Striped="true" Hover="true"
             SortMode="SortMode.Multiple" Filterable="true" QuickFilter="@_quickFilter">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Einträge</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="_search" Placeholder="Suchen..." Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.Zeitstempel" Title="Zeitstempel" />
        <PropertyColumn Property="x => x.Ebene" Title="Ebene" />
        <PropertyColumn Property="x => x.Quelle" Title="Quelle" />
        <PropertyColumn Property="x => x.BlockTyp" Title="Block" />
        <PropertyColumn Property="x => x.Bmk" Title="BMK" />
        <PropertyColumn Property="x => x.Nachricht" Title="Nachricht" />
    </Columns>
    <PagerContent>
        <MudDataGridPager T="LogEntry" />
    </PagerContent>
</MudDataGrid>

@code {
    private string _search = string.Empty;
    private List<LogEntry> _entries = [];

    protected override void OnInitialized()
    {
        LoadLatest();
        PersistentLog.LogAdded += OnLogAdded;
    }

    private void OnLogAdded(EppConfig.Services.PersistentLogEntry entry)
    {
        _ = InvokeAsync(() =>
        {
            LoadLatest();
            StateHasChanged();
        });
    }

    private void LoadLatest()
    {
        _entries = PersistentLog.GetLatest(500)
            .Select(entry => new LogEntry(
                entry.Timestamp.LocalDateTime,
                entry.Level,
                entry.Message,
                entry.Source,
                entry.BlockType ?? string.Empty,
                entry.Bmk ?? string.Empty))
            .ToList();
    }

    private Func<LogEntry, bool> _quickFilter => entry =>
    {
        if (string.IsNullOrWhiteSpace(_search)) return true;

        return entry.Nachricht.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || entry.Ebene.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || entry.Quelle.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || entry.BlockTyp.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || entry.Bmk.Contains(_search, StringComparison.OrdinalIgnoreCase);
    };

    public void Dispose()
    {
        PersistentLog.LogAdded -= OnLogAdded;
    }

    public record LogEntry(DateTime Zeitstempel, string Ebene, string Nachricht, string Quelle, string BlockTyp, string Bmk);
}
